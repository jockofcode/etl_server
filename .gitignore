# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.erb

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage SQLite databases, but keep the directory and app data.
/storage/*.sqlite3
/storage/*.sqlite3-shm
/storage/*.sqlite3-wal

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore node_modules.
/node_modules

# Ignore Byebug history.
.byebug_history
